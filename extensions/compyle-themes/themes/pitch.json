	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#E5E4E4"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#666565",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
