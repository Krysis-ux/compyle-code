	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#D8D6DF"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#5F5E63",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#DE9400"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#FF7B26"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#F269CB"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#FF6AFF",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"keyword.import",
				"keyword.from"
			],
			"settings": {
				"foreground": "#FF6AFF"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#FFB000"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call entity.name.function"
			],
			"settings": {
				"foreground": "#FF6AFF"
			}
		},
		{
			"scope": [
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#D8D6DF"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#D8D6DF"
			}
		},
		{
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#FF7B26",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.language.this",
				"variable.language.self"
			],
			"settings": {
				"foreground": "#F269CB",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
