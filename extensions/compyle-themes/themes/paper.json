	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#181611"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#2F2E2B",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
