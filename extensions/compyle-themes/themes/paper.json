				"string.template"
			],
			"settings": {
				"foreground": "#8A0000"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#940000"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#7E0062"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
