	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#D2D4D7"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#5C5D5F",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#F46EB4"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#FF7B26"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#F269CB"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#00B7FF",
				"fontStyle": ""
			}
		},
		{
