	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#14151D"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#2D2D32",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#880000"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#940000"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#7E0062"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#4B3ADA",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"keyword.import",
				"keyword.from"
			],
			"settings": {
				"foreground": "#4B3ADA"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#823300"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call entity.name.function"
			],
			"settings": {
				"foreground": "#4B3ADA"
			}
		},
		{
			"scope": [
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#14151D"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#14151D"
			}
		},
		{
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#940000",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.language.this",
				"variable.language.self"
			],
			"settings": {
				"foreground": "#7E0062",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"meta.property-name",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#14151D"
			}
		},
		{
			"scope": [
				"punctuation.definition",
				"punctuation.separator",
				"punctuation.terminator",
				"meta.brace"
			],
			"settings": {
				"foreground": "#6D7083"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#4B3ADA"
