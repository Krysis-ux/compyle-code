			],
			"settings": {
				"foreground": "#B7B7B7"
			}
		},
		{
			"scope": [
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#D7D7D7"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other"
			],
