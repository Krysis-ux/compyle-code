	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#D6D7DF"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#5E5E63",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#B786FF"
			}
		},
		{
