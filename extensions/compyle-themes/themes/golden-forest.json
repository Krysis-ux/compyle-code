				"keyword.from"
			],
			"settings": {
				"foreground": "#39C34B"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#823300"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
