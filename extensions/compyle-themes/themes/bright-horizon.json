	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#1A1513"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#302D2C",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#005900"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#940000"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#7E0062"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#FF5D48",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"keyword.import",
				"keyword.from"
			],
			"settings": {
				"foreground": "#FF5D48"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#823300"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#005A60"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call entity.name.function"
			],
			"settings": {
				"foreground": "#FF5D48"
			}
		},
		{
			"scope": [
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#1A1513"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#1A1513"
			}
		},
		{
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#940000",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.language.this",
				"variable.language.self"
			],
			"settings": {
				"foreground": "#7E0062",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"meta.property-name",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#1A1513"
			}
		},
		{
			"scope": [
				"punctuation.definition",
				"punctuation.separator",
				"punctuation.terminator",
				"meta.brace"
			],
			"settings": {
				"foreground": "#746560"
			}
		},
		{
