	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#8AC2D0"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#3A555B",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#E175D9"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#FF7B26"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#F269CB"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#00B5DB",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"keyword.import",
				"keyword.from"
			],
			"settings": {
				"foreground": "#00B5DB"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#FFB000"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
