	"tokenColors": [
		{
			"scope": [
				""
			],
			"settings": {
				"foreground": "#CCD1DA"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#595C60",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#FF7643"
			}
		},
		{
			"scope": [
				"string.regexp"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character"
			],
			"settings": {
				"foreground": "#FF7B26"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#F269CB"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"storage.modifier",
				"storage.type"
			],
			"settings": {
				"foreground": "#9E98FF",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"keyword.import",
				"keyword.from"
			],
			"settings": {
				"foreground": "#9E98FF"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.enum",
				"support.class"
			],
			"settings": {
				"foreground": "#FFB000"
			}
		},
		{
			"scope": [
				"support.type",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#00D9DB"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call entity.name.function"
			],
			"settings": {
				"foreground": "#9E98FF"
			}
		},
		{
			"scope": [
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#CCD1DA"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other"
			],
			"settings": {
				"foreground": "#CCD1DA"
			}
		},
		{
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#FF7B26",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.language.this",
				"variable.language.self"
			],
			"settings": {
				"foreground": "#F269CB",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"meta.property-name",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#CCD1DA"
			}
		},
		{
			"scope": [
				"punctuation.definition",
				"punctuation.separator",
				"punctuation.terminator",
				"meta.brace"
			],
			"settings": {
				"foreground": "#475670"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#9E98FF"
